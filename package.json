{
  "name": "tadka-caching-demo",
  "version": "1.0.0",
  "description": "Tadka App - Caching Demo for The Desi Architect caching masterclass",
  "scripts": {
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down -v",
    "demo:reset": "node seed.js",
    "api:no-cache": "cross-env CACHE_ENABLED=false node server.js",
    "api:cache-aside": "cross-env CACHE_ENABLED=true node server.js",
    "api:labs:herd-off": "cross-env CACHE_ENABLED=true MENU_TTL_SECONDS=2 COALESCE_MISSES=false node server.js",
    "api:labs:herd-on": "cross-env CACHE_ENABLED=true MENU_TTL_SECONDS=2 COALESCE_MISSES=true node server.js",
    "api:labs:negative-off": "cross-env CACHE_ENABLED=true NEGATIVE_CACHE_ENABLED=false node server.js",
    "api:labs:negative-on": "cross-env CACHE_ENABLED=true NEGATIVE_CACHE_ENABLED=true node server.js",
    "api:labs:ttl": "cross-env CACHE_ENABLED=true MENU_TTL_SECONDS=5 node server.js",
    "demo:performance:no-cache": "node demos/performance-no-cache.js",
    "demo:performance:cache-aside": "node demos/performance-cache-aside.js",
    "demo:invalidation:stale-cache": "node demos/invalidation-stale-cache.js",
    "demo:invalidation:explicit": "node demos/invalidation-explicit.js",
    "demo:invalidation:ttl-stale": "node demos/ttl-stale.js",
    "demo:invalidation:ttl-expired": "node demos/ttl-expired.js",
    "demo:traps:negative-cache:off": "node demos/negative-cache-off.js",
    "demo:traps:negative-cache:on": "node demos/negative-cache-on.js",
    "demo:traps:thundering-herd:off": "node demos/thundering-herd-off.js",
    "demo:traps:thundering-herd:on": "node demos/thundering-herd-on.js",
    "demo:patterns:write-compare": "node demos/write-compare.js",
    "test:smoke": "node scripts/smoke-test.mjs"
  },
  "dependencies": {
    "cross-env": "^7.0.3",
    "express": "^4.21.2",
    "ioredis": "^5.6.1",
    "pg": "^8.14.1"
  }
}
